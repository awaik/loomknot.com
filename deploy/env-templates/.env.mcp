# MCP Server
NODE_ENV=production
PORT=4100

# Database
DATABASE_URL=postgresql://USER:PASSWORD@loomknot-postgres:5432/loomknot

# Redis (for pub/sub between MCP and API)
REDIS_URL=redis://:PASSWORD@loomknot-redis:6379

# JWT (validate agent tokens)
JWT_ACCESS_SECRET=CHANGE_ME_same_as_backend

# App URL (for generating links in tool responses)
APP_URL=https://loomknot.com

# MCP Server config
MCP_SERVER_NAME=loomknot
MCP_SERVER_VERSION=0.1.0

# Rate limiting
MCP_RATE_LIMIT_RPM=60
MCP_RATE_LIMIT_BURST=10
