# NestJS Backend
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://loomknot.com

# Database
DATABASE_URL=postgresql://USER:PASSWORD@loomknot-postgres:5432/loomknot

# Redis
REDIS_URL=redis://:PASSWORD@loomknot-redis:6379

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ENDPOINT=loomknot-minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=loomknot

# Email (Resend)
RESEND_API_KEY=re_CHANGE_ME

# Sentry
SENTRY_DSN=

# OpenAI (built-in agent)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
